{
  "name": "coding-stats",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "analyze": "npx vite-bundle-visualizer --open --",
    "debug": "NODE_OPTIONS=--inspect ./node_modules/.bin/vite dev",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "playwright test",
    "ui": "vitest --ui",
    "test:unit": "vitest",
    "test:ui": "playwright test --ui",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --plugin-search-dir . --write .",
    "webhint": "hint",
    "sb:start": "supabase start && pnpm sb:dump:remote && pnpm sb:reset && pnpm sb:seed && pnpm sb:types",
    "sb:stop": "supabase stop",
    "dev:fresh": "pnpm sb:start && vite dev",
    "dev:resume": "supabase start && pnpm sb:types && vite dev",
    "sb:dump": "supabase db dump --data-only -f supabase/seed.sql",
    "sb:dump:remote": "supabase db dump --data-only --linked -f supabase/seed.sql",
    "sb:types": "supabase gen types typescript --local > src/lib/database.types.ts",
    "sb:reset": "psql postgresql://postgres:postgres@localhost:54322/postgres < supabase/reset.sql",
    "sb:seed": "psql postgresql://postgres:postgres@localhost:54322/postgres < supabase/seed.sql",
    "codegen": "rm -rf src/lib/generated/openapi/shortcut; openapi-generator-cli generate -i https://developer.shortcut.com/api/rest/v3/shortcut.swagger.json -o src/lib/generated/openapi/shortcut -g typescript-fetch --additional-properties=supportsES6=true,npmVersion=6.9.0,typescriptThreePlus=true",
    "spell": "cspell \"src/**/*.{ts,svelte,js}\" --no-progress",
    "verify": "pnpm check && pnpm lint && pnpm spell",
    "ci": "pnpm check && pnpm lint && pnpm spell && pnpm test:unit",
    "verify:quiet": "pnpm tsx ./scripts/verify-quiet.ts",
    "ci:quiet": "pnpm tsx ./scripts/ci-quiet.ts",
    "deliver": "pnpm tsx ./scripts/deliver.ts",
    "closeout-stack": "pnpm tsx ./scripts/closeout-stack.ts"
  },
  "devDependencies": {
    "@edge-runtime/vm": "5.0.0",
    "@eslint/js": "9.39.4",
    "@playwright/test": "1.59.1",
    "@supabase/supabase-js": "2.105.1",
    "@sveltejs/adapter-vercel": "6.3.3",
    "@sveltejs/kit": "2.58.0",
    "@tailwindcss/postcss": "4.2.4",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/svelte": "^5.2.7",
    "@testing-library/user-event": "14.6.1",
    "@types/jest": "30.0.0",
    "@types/lodash": "4.17.24",
    "@types/testing-library__jest-dom": "6.0.0",
    "@typescript-eslint/eslint-plugin": "8.59.1",
    "@typescript-eslint/parser": "8.59.1",
    "@vercel/analytics": "1.6.1",
    "@vitest/coverage-istanbul": "4.1.5",
    "@vitest/coverage-v8": "4.1.5",
    "@vitest/ui": "4.1.5",
    "cspell": "10.0.0",
    "daisyui": "5.5.19",
    "dayjs": "1.11.20",
    "echarts": "6.0.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-svelte": "3.17.1",
    "globals": "16.5.0",
    "hint": "7.1.13",
    "iconify-icon": "3.0.2",
    "jsdom": "27.4.0",
    "lodash": "4.18.1",
    "msw": "2.13.6",
    "postcss": "8.5.13",
    "prettier": "3.8.3",
    "prettier-plugin-svelte": "3.5.1",
    "prettier-plugin-tailwindcss": "0.8.0",
    "sharp": "0.34.5",
    "svelte": "5.55.5",
    "svelte-check": "4.4.7",
    "svelte-eslint-parser": "1.6.0",
    "svelte-fragment-component": "1.2.0",
    "svelte-htm": "1.2.0",
    "svelte-media": "0.1.5",
    "tailwindcss": "^4.2.4",
    "terser": "5.46.2",
    "tippy.js": "6.3.7",
    "tslib": "2.8.1",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vite-plugin-compression": "0.5.1",
    "vite-plugin-inspect": "11.3.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": "^24.12.0",
    "npm": "^11.6.2"
  },
  "type": "module",
  "dependencies": {
    "@sentry/opentelemetry": "10.51.0",
    "@sentry/sveltekit": "10.51.0",
    "@supabase/ssr": "0.10.2",
    "@sveltejs/vite-plugin-svelte": "6.2.4"
  }
}
